NIM_LLM_IMAGE=nvcr.io/nim/<your-org>/<your-model-image>:<tag>
NIM_MODEL_PATH=hf://meta-llama/Llama-3.1-8B-Instruct
NIM_MODEL_PROFILE=
NIM_SERVER_PORT=8000
NIM_CACHE_DIR=./.nim-cache
HF_TOKEN=
NGC_API_KEY=
NGC_CLI_API_KEY=
MODELSCOPE_API_TOKEN=
NIM_LOG_LEVEL=INFO
NIM_REQUEST_MODEL=hf://meta-llama/Llama-3.1-8B-Instruct
NIM_API_KEY=
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

HARNESS_BACKEND=nvidia_nim
HARNESS_BASE_URL=http://nvidia-nim:8000/v1
HARNESS_MODEL=${NIM_REQUEST_MODEL}
HARNESS_API_KEY=${NIM_API_KEY}
HARNESS_CONFIG=./harness-nvidia.yaml
